<div class="form-wrapper">
    <div class="form-box">
        <h2 class="form-title">Mes informations</h2>

        {{ form_start(form, {'action': path('dashboard_edit_infos'), 'method': 'POST'}) }}

        <div class="form-group">
            {{ form_label(form.firstName, 'Prénom', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.firstName, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.lastName, 'Nom', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.lastName, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.userName, 'Nom d’utilisateur', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.userName, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.city, 'Ville', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.city, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.zipCode, 'Code postal', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.zipCode, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.phoneNumber, 'Téléphone', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.phoneNumber, { 'attr': {'class':'form-input'} }) }}
        </div>

        <div class="form-group">
            {{ form_label(form.birthDate, 'Date de naissance', { 'label_attr': {'class':'form-label'} }) }}
            {{ form_widget(form.birthDate, { 'attr': {'class':'form-input'} }) }}
        </div>

        <button type="submit" class="btn btn-submit">Enregistrer</button>

        {{ form_end(form) }}
    </div>
</div>
